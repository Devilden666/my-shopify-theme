{% unless customer %}
  <script>window.location.href = "{{ routes.account_login_url }}";</script>
{% endunless %}

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2" defer></script>

<style>
  /* BRUTALIST VAULT CSS */
  .dd-dashboard-wrapper { width: 100vw; min-height: 100vh; background-color: #000000; color: #ffffff; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; padding: 120px 5vw 80px 5vw; box-sizing: border-box; }
  .dd-dash-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid #333; padding-bottom: 20px; margin-bottom: 40px; }
  .dd-dash-title { font-size: clamp(30px, 5vw, 50px); text-transform: uppercase; margin: 0; line-height: 1; letter-spacing: -1px; }
  .dd-user-meta { font-size: 11px; text-align: right; letter-spacing: 1.5px; color: #888; text-transform: uppercase; }
  .dd-user-meta span { color: #fff; font-weight: bold; }
  .dd-logout { color: #ff3333; text-decoration: none; margin-top: 8px; display: inline-block; transition: 0.3s; border: 1px solid transparent; padding: 4px 8px; }
  .dd-logout:hover { color: #ff6666; border: 1px solid #ff3333; }

  /* TABS */
  .dd-dash-nav { display: flex; gap: 20px; margin-bottom: 40px; border-bottom: 1px solid #222; padding-bottom: 1px; }
  .dd-tab-btn { background: transparent; color: #666; border: 1px solid transparent; border-bottom: none; padding: 12px 24px; font-size: 11px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 2px; transition: 0.3s; }
  .dd-tab-btn.active { background: #111; color: #fff; border: 1px solid #333; border-bottom: 1px solid #111; transform: translateY(1px); }
  .dd-tab-btn:hover:not(.active) { color: #fff; }

  .dd-panel { display: none; }
  .dd-panel.active { display: block; animation: fadeIn 0.4s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

  /* DATAGRID / LIST VIEWS */
  .dd-list-header { display: grid; grid-template-columns: 80px 2fr 1fr 1fr; gap: 20px; font-size: 10px; color: #666; border-bottom: 1px solid #333; padding-bottom: 10px; margin-bottom: 10px; letter-spacing: 2px; text-transform: uppercase; }
  .dd-list-row { display: grid; grid-template-columns: 80px 2fr 1fr 1fr; gap: 20px; align-items: center; padding: 15px 0; border-bottom: 1px solid #1a1a1a; font-size: 13px; transition: background 0.2s; }
  .dd-list-row:hover { background: #0a0a0a; }
  
  .dd-col-thumb img { width: 60px; height: 60px; object-fit: cover; border-radius: 2px; border: 1px solid #333; }
  .dd-col-thumb .no-img { width: 60px; height: 60px; background: #111; display: flex; align-items: center; justify-content: center; font-size: 9px; color: #444; border: 1px dashed #333; }
  .dd-col-price { font-family: monospace; font-size: 14px; color: #ccc; }
  
  /* STATUS BADGES (Dynamic Colors) */
  .dd-status-badge { display: inline-block; padding: 6px 12px; font-size: 9px; font-weight: 900; letter-spacing: 1px; border-radius: 2px; text-transform: uppercase; }
  .status-pending { background: #332b00; color: #ffcc00; border: 1px solid #665200; }
  .status-received { background: #002244; color: #3399ff; border: 1px solid #003366; }
  .status-listed { background: #003311; color: #33cc66; border: 1px solid #004d1a; }
  .status-sold { background: #330000; color: #ff3333; border: 1px solid #660000; }
  .status-paid { background: #ffffff; color: #000000; }

  .dd-empty-state { text-align: center; padding: 80px 20px; border: 1px dashed #333; color: #666; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; background: #050505; }
  .dd-action-btn { background: #fff; color: #000; border: none; padding: 14px 28px; font-size: 11px; font-weight: bold; cursor: pointer; letter-spacing: 2px; text-decoration: none; display: inline-block; margin-top: 25px; transition: 0.3s; }
  .dd-action-btn:hover { background: #ccc; }

  @media (max-width: 768px) {
    .dd-list-header { display: none; }
    .dd-list-row { grid-template-columns: 70px 1fr; grid-template-rows: auto auto; gap: 10px 15px; padding: 20px 0; }
    .dd-col-thumb { grid-row: span 2; }
    .dd-col-title { font-size: 14px; }
    .dd-col:nth-child(3), .dd-col:nth-child(4) { font-size: 11px; }
    .dd-status-badge { padding: 4px 8px; font-size: 8px; }
  }
</style>

<div class="dd-dashboard-wrapper">
  <div class="dd-dash-header">
    <h1 class="dd-dash-title">VAULT<br>ACCESS</h1>
    <div class="dd-user-meta">
      USER: <span>{{ customer.name }}</span><br>
      <a href="{{ routes.account_logout_url }}" class="dd-logout">[ TERMINATE SESSION ]</a>
    </div>
  </div>

  <div class="dd-dash-nav">
    <button class="dd-tab-btn active" data-target="panel-acquisitions">ACQUISITIONS</button>
    <button class="dd-tab-btn" data-target="panel-consignments">CONSIGNMENTS</button>
  </div>

  <div class="dd-panel active" id="panel-acquisitions">
    {% if customer.orders.size > 0 %}
      <div class="dd-list-header" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
        <div>ORDER</div>
        <div>DATE</div>
        <div>STATUS</div>
        <div>TOTAL</div>
      </div>
      {% for order in customer.orders %}
        <div class="dd-list-row" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
          <div class="dd-col">{{ order.name }}</div>
          <div class="dd-col">{{ order.created_at | date: "%B %d, %Y" }}</div>
          <div class="dd-col">{{ order.fulfillment_status_label | default: 'Unfulfilled' }}</div>
          <div class="dd-col dd-col-price">{{ order.total_price | money }}</div>
        </div>
      {% endfor %}
    {% else %}
      <div class="dd-empty-state">
        <p>NO PAST ACQUISITIONS FOUND IN THE ARCHIVE.</p>
        <a href="/collections/all" class="dd-action-btn">BROWSE SHOP</a>
      </div>
    {% endif %}
  </div>

  <div class="dd-panel" id="panel-consignments">
    <div id="dd-consignments-container">
      <div style="padding: 60px; text-align: center; color: #555; font-size: 11px; letter-spacing: 2px;">
        ESTABLISHING SECURE CONNECTION TO VAULT...
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // TAB SWITCHING
    const tabs = document.querySelectorAll('.dd-tab-btn');
    const panels = document.querySelectorAll('.dd-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.target).classList.add('active');
      });
    });

    // --- SUPABASE DATA FETCH ---
    const supabaseUrl = 'https://orvqtdhcsmxqmhnakolj.supabase.co';
    const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9ydnF0ZGhjc214cW1obmFrb2xqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMxNjU3MzAsImV4cCI6MjA4ODc0MTczMH0.5s7DWkriiqzxKx2slcZl_9kLWmp9s8LSpLUVYasYefg';
    
    if (window.supabase) {
      const supabase = window.supabase.createClient(supabaseUrl, supabaseKey);
      const customerEmail = "{{ customer.email }}";

      async function fetchConsignments() {
        const container = document.getElementById('dd-consignments-container');
        
        // Fetch all items submitted by this exact user
        const { data, error } = await supabase
          .from('consignments')
          .select('*')
          .eq('customer_email', customerEmail)
          .order('created_at', { ascending: false });

        if (error) {
          container.innerHTML = `<div class="dd-empty-state"><p>SYSTEM ERROR: COULD NOT CONNECT TO SECURE DATABASE.</p></div>`;
          return;
        }

        if (data && data.length > 0) {
          let html = `
            <div class="dd-list-header">
              <div>IMAGE</div>
              <div>ARTIFACT</div>
              <div>PAYOUT</div>
              <div>STATUS</div>
            </div>
          `;

          let formatter = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });

          data.forEach(item => {
            // Extract the first image from the array to use as a thumbnail
            let thumbHtml = '<div class="no-img">NO IMG</div>';
            if (item.image_urls && item.image_urls.length > 0) {
              thumbHtml = `<img src="${item.image_urls[0]}" alt="Artifact Thumbnail">`;
            }

            // Calculate the actual payout (Minus 15% fee)
            let rawPrice = parseFloat(item.price) || 0;
            let finalPayout = rawPrice - (rawPrice * 0.15);

            // Format dynamic status badge
            let rawStatus = item.status || 'PENDING';
            let statusClass = `status-${rawStatus.toLowerCase().replace(' ', '-')}`;

            html += `
              <div class="dd-list-row">
                <div class="dd-col dd-col-thumb">${thumbHtml}</div>
                <div class="dd-col dd-col-title" style="text-transform: uppercase; font-weight: bold; letter-spacing: 1px;">${item.item_name}</div>
                <div class="dd-col dd-col-price">${formatter.format(finalPayout)}</div>
                <div class="dd-col">
                  <span class="dd-status-badge ${statusClass}">${rawStatus}</span>
                </div>
              </div>
            `;
          });

          container.innerHTML = html;
        } else {
          container.innerHTML = `
            <div class="dd-empty-state">
              <p>NO ACTIVE CONSIGNMENTS FOUND IN YOUR VAULT.</p>
              <a href="/pages/thrift" class="dd-action-btn">INITIATE SUBMISSION</a>
            </div>
          `;
        }
      }

      // Execute fetch
      fetchConsignments();
    }
  });
</script>