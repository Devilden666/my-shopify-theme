<style>
  /* 1. AGGRESSIVELY HIDE DEFAULT SHOPIFY SECTIONS */
  #shopify-section-main-collection-banner,
  #shopify-section-main-collection-product-grid,
  .collection-hero,
  .collection-filters,
  facets-container {
    display: none !important;
    height: 0 !important;
    opacity: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }

  /* 2. THE ALAÏA-STYLE MASTER GRID */
  .dd-collection-wrapper {
    background-color: #ffffff;
    width: 100%;
    min-height: 100vh;
    padding-top: 100px; 
  }

  .dd-alaia-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px; 
    background-color: #ffffff;
    padding: 4px; 
  }

  /* INDIVIDUAL PRODUCT CARD */
  .dd-alaia-card {
    position: relative;
    background-color: #f6f6f6; 
    height: 85vh; 
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    overflow: hidden;
    cursor: pointer;
    
    /* CRITICAL MOBILE UI FIXES */
    -webkit-tap-highlight-color: transparent;
    -webkit-user-select: none;
    user-select: none;
    touch-action: manipulation;
  }

  .dd-alaia-card .img-wrapper {
    width: 75%;
    height: 75%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    transform: translateZ(0);
  }

  .dd-alaia-card img, .dd-alaia-card svg {
    position: absolute;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    will-change: transform, opacity;
    transition: opacity 0.6s ease, transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Fallback SVG styling */
  .dd-alaia-card svg {
    width: 50%;
    height: 50%;
    fill: #cccccc;
  }

  .img-primary {
    z-index: 2;
    opacity: 1;
    transform: translateZ(0); /* Hardware acceleration */
  }

  .img-hover {
    z-index: 1;
    opacity: 0; 
    transform: scale(1.05) translateZ(0);
  }

  .dd-alaia-info {
    position: absolute;
    bottom: 40px;
    left: 0;
    width: 100%;
    text-align: center;
    opacity: 0; 
    transform: translateY(10px) translateZ(0);
    transition: opacity 0.4s ease, transform 0.4s ease;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 8px;
    will-change: transform, opacity;
  }

  .dd-item-title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    color: #000000;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0;
  }

  .dd-item-price {
    font-family: monospace;
    color: #555555;
    font-size: 12px;
    font-weight: 900;
    margin: 0;
  }

  /* =========================================
     DESKTOP INTERACTION (Hover Devices Only)
     ========================================= */
  @media (hover: hover) and (pointer: fine) {
    .dd-alaia-card:hover .img-primary {
      opacity: 0; 
    }
    .dd-alaia-card:hover .img-hover {
      opacity: 1; 
      transform: scale(1) translateZ(0);
    }
    .dd-alaia-card:hover .dd-alaia-info {
      opacity: 1;
      transform: translateY(0) translateZ(0);
    }
  }

  /* =========================================
     MOBILE INTERACTION (Touch Devices Only)
     ========================================= */
  @media (hover: none) and (pointer: coarse) {
    /* Instantly depress the item when a user taps it */
    .dd-alaia-card:active .img-wrapper {
      transform: scale(0.96) translateZ(0);
      transition: transform 0.1s ease;
    }
    .dd-alaia-card:active .dd-alaia-info {
      transform: scale(0.96) translateZ(0);
      transition: transform 0.1s ease;
    }
  }

  /* PAGINATION STYLING */
  .dd-pagination {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    gap: 20px;
    padding: 80px 0;
    background: #ffffff;
  }

  .dd-pagination a, .dd-pagination span {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 2px;
    color: #000000;
    text-decoration: none;
    text-transform: uppercase;
    transition: opacity 0.3s;
  }

  .dd-pagination a:hover {
    opacity: 0.5;
  }

  .dd-pagination .current {
    border-bottom: 2px solid #000;
    padding-bottom: 2px;
  }

  /* MOBILE OPTIMIZATIONS */
  @media screen and (max-width: 1024px) {
    .dd-alaia-grid { grid-template-columns: repeat(2, 1fr); }
  }
  
  @media screen and (max-width: 768px) {
    .dd-alaia-grid { grid-template-columns: 1fr; }
    .dd-alaia-card { height: 70vh; }
    
    /* On mobile devices, force the info to be visible permanently */
    .dd-alaia-info { 
      opacity: 1; 
      transform: translateY(0) translateZ(0); 
      bottom: 25px;
    }
  }
</style>

<div class="dd-collection-wrapper">
  <div class="dd-alaia-grid">
    
    {% paginate collection.products by 24 %}
      
      {% for product in collection.products %}
        <a href="{{ product.url }}" class="dd-alaia-card">
          
          <div class="img-wrapper">
            {% if product.featured_media %}
              
              {%- comment -%} 
                CRITICAL FIX: Responsive image tags. The browser will automatically 
                choose the 400px or 600px version on mobile, preventing massive downloads. 
              {%- endcomment -%}
              {{ product.featured_media | image_url: width: 1200 | image_tag: 
                 class: 'img-primary', 
                 loading: 'lazy', 
                 sizes: '(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw', 
                 widths: '400, 600, 800, 1200' 
              }}
              
              {% if product.media.size > 1 %}
                {{ product.media[1] | image_url: width: 1200 | image_tag: 
                   class: 'img-hover', 
                   loading: 'lazy', 
                   sizes: '(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw', 
                   widths: '400, 600, 800, 1200' 
                }}
              {% else %}
                {{ product.featured_media | image_url: width: 1200 | image_tag: 
                   class: 'img-hover', 
                   loading: 'lazy', 
                   sizes: '(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw', 
                   widths: '400, 600, 800, 1200' 
                }}
              {% endif %}

            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'img-primary' }}
              {{ 'product-1' | placeholder_svg_tag: 'img-hover' }}
            {% endif %}
          </div>

          <div class="dd-alaia-info">
            <h3 class="dd-item-title">{{ product.title }}</h3>
            <p class="dd-item-price">{{ product.price | money }}</p>
          </div>

        </a>
      {% else %}
        <div style="padding: 150px 40px; text-align: center; grid-column: 1 / -1; font-family: 'Helvetica Neue', Helvetica, sans-serif; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; color: #000000; background: #ffffff;">
          NO ARTIFACTS FOUND IN THIS ARCHIVE.
          <br><br>
          <span style="font-size: 9px; color: #888888;">Add products to this Collection in your Shopify Admin.</span>
        </div>
      {% endfor %}

      {% if paginate.pages > 1 %}
        <div class="dd-pagination">
          {{ paginate | default_pagination: next: 'NEXT', previous: 'PREV' }}
        </div>
      {% endif %}

    {% endpaginate %}
  </div>
</div>

{% schema %}
{
  "name": "Damso Archive Grid",
  "settings": [],
  "presets": [
    {
      "name": "Damso Archive Grid",
      "category": "Collection"
    }
  ]
}
{% endschema %}