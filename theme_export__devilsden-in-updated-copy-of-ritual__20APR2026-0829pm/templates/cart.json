ignment":"flex-start","gap":28,"color_scheme":"scheme-1","padding-block-start":48,"padding-block-end":48}},"custom_liquid_BDB87n":{"type":"custom-liquid","name":"t:names.custom_liquid","settings":{"custom_liquid":"<style>\n\/* MAISON CART ARCHITECTURE - LIMITLESS OVERRIDE *\/\n\n\/* 1. KILLS THE SALMON BACKGROUND - AGGRESSIVE TARGETING *\/\n#main-cart-footer,\n.cart__footer,\n.cart__footer-wrapper,\n.cart__footer .cart__blocks,\n.cart__blocks {\n  background: #050505 !important;\n  background-color: #050505 !important;\n  --color-background: 5, 5, 5 !important; \/* Kills native theme variables *\/\n  border-radius: 0px !important;\n}\n\n.cart__footer .cart__blocks {\n  border: 1px solid #333333 !important;\n  padding: 40px !important;\n  box-shadow: 0 20px 40px rgba(0,0,0,0.5) !important;\n}\n\n\/* 2. Global Cart Text & Headers *\/\n.title-wrapper-with-link .title, \n.cart-item__name, \nh1, h2, h3, h4 {\n  font-family: 'Helvetica Neue', Helvetica, sans-serif !important;\n  font-weight: 900 !important;\n  text-transform: uppercase !important;\n  letter-spacing: 1px !important;\n  color: #ffffff !important;\n}\n\n\/* 3. Cart Item Rows Formatting *\/\n.cart-items th {\n  border-bottom: 1px solid #333333 !important;\n  color: #888888 !important;\n  font-size: 10px !important;\n  letter-spacing: 1px !important;\n  text-transform: uppercase !important;\n}\n\n.cart-item {\n  border-bottom: 1px solid #222222 !important;\n}\n\n.cart-item__price-wrapper *, \n.cart-item__details * {\n  color: #cccccc !important;\n  font-family: monospace !important;\n  font-size: 13px !important;\n}\n\n\/* 4. Summary Text Adjustments *\/\n.totals__subtotal-value, \n.totals__subtotal {\n  color: #ffffff !important;\n  font-weight: 900 !important;\n  font-size: 16px !important;\n  letter-spacing: 1px !important;\n}\n\n.tax-note {\n  color: #666666 !important;\n  font-size: 11px !important;\n  text-transform: uppercase !important;\n  letter-spacing: 0.5px !important;\n}\n\n\/* 5. The Checkout Button (Heavy Physics Hover) *\/\n.cart__checkout-button, \n#checkout {\n  background-color: #ffffff !important;\n  color: #000000 !important;\n  font-family: 'Helvetica Neue', Helvetica, sans-serif !important;\n  font-weight: 900 !important;\n  font-size: 12px !important;\n  letter-spacing: 2px !important;\n  text-transform: uppercase !important;\n  border: 1px solid #ffffff !important;\n  border-radius: 0px !important;\n  padding: 20px !important;\n  width: 100% !important;\n  transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1) !important;\n  cursor: pointer !important;\n  margin-top: 20px !important;\n}\n\n.cart__checkout-button:hover, \n#checkout:hover {\n  background-color: #000000 !important;\n  color: #ffffff !important;\n  box-shadow: inset 0 0 0 1px #ffffff !important;\n}\n\n\/* 6. Quantity Selectors *\/\n.quantity {\n  background-color: transparent !important;\n  border: 1px solid #333333 !important;\n  border-radius: 0px !important;\n}\n\n.quantity__input, \n.quantity__button {\n  color: #ffffff !important;\n}\n<\/style>","color_scheme":"scheme-1","section_width":"page-width","padding-block-start":0,"padding-block-end":0}}},"order":["cart-section","product_list_fUKeNV","custom_liquid_BDB87n"]}