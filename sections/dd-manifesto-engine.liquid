<script src="https://unpkg.com/split-type"></script>

<div class="dd-manifesto-container" id="manifesto-{{ section.id }}">
  
  <div class="manifesto-bg">
    <canvas id="void-canvas-{{ section.id }}"></canvas>
  </div>

  <div class="manifesto-content">
    
    <section class="m-hero">
      <div class="m-badge-wrap">
        <span class="m-glass-badge">LA MAISON</span>
      </div>
      <h1 class="m-title kinetic-header">DEVIL'S<br>DEN</h1>
      <div class="m-scroll-indicator">
        <span class="m-line"></span>
        <span class="m-label">SCROLL TO INVOKE</span>
      </div>
    </section>

    <section class="m-syndicate">
      <div class="m-manifesto-grid">
        <div class="m-col-left">
           <span class="m-coord">18.2818° N, 72.8808° E</span>
        </div>
        <div class="m-col-main">
          <p class="m-paragraph reveal-text">
            We do not manufacture products. We isolate artifacts from the noise of the modern world. Devil's Den is a sanctuary for the high-fashion anomaly.
          </p>
          <p class="m-paragraph reveal-text">
            Every piece in our archive—be it heavy-gauge hardware, structured apparel, or rare objects—is engineered with the weight of tradition and the kinetic energy of the future.
          </p>
          <p class="m-paragraph reveal-text">
            To wear Devil's Den is to inhabit the space between the structural and the fluid. A digital house for physical manifestations.
          </p>
        </div>
      </div>
    </section>

    <section class="m-footer">
       <h2 class="m-footer-title reveal-text">JOIN THE SYNDICATE.</h2>
       <div class="m-cta-wrap">
          <a href="/collections/all" class="m-cta-btn">ENTER THE ARCHIVE</a>
       </div>
    </section>

  </div>

  <div class="manifesto-dial-anchor">
     <div class="pod-morph-container" onclick="window.location.href='/'">
        <div class="pod-spin-bg"><div class="pod-dent"></div></div>
        <div class="pod-center"><div class="center-symbol"></div></div>
     </div>
  </div>

</div>

<style>
  :root { --m-bg: #0a0a0a; --m-text: #ffffff; --m-accent: #8B0000; }
  
  .dd-manifesto-container { 
    background: var(--m-bg); color: var(--m-text); 
    font-family: 'Helvetica Neue', Helvetica, sans-serif; 
    overflow-x: hidden; position: relative;
  }

  .manifesto-bg { position: fixed; inset: 0; z-index: 1; pointer-events: none; }
  #void-canvas-{{ section.id }} { width: 100%; height: 100%; opacity: 0.6; }

  .manifesto-content { position: relative; z-index: 2; }

  /* HERO */
  .m-hero { height: 100vh; height: 100dvh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; }
  .m-glass-badge { 
    background: rgba(255,255,255,0.05); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 20px;
    padding: 6px 15px; font-size: 10px; font-weight: 800; letter-spacing: 2px;
  }
  .m-title { font-size: clamp(4rem, 15vw, 12rem); font-weight: 900; line-height: 0.85; margin: 40px 0; letter-spacing: -4px; }

  .m-scroll-indicator { position: absolute; bottom: 8vh; display: flex; flex-direction: column; align-items: center; gap: 15px; }
  .m-line { width: 1px; height: 60px; background: linear-gradient(to bottom, var(--m-accent), transparent); }
  .m-label { font-size: 9px; font-weight: 800; letter-spacing: 2px; color: #555; }

  /* MANIFESTO BODY */
  .m-syndicate { padding: 15vh 5vw; min-height: 100vh; display: flex; justify-content: center; }
  .m-manifesto-grid { display: grid; grid-template-columns: 1fr 2fr; max-width: 1400px; width: 100%; gap: 40px; }
  .m-coord { font-family: monospace; font-size: 11px; color: #666; position: sticky; top: 150px; }
  
  .m-paragraph { 
    font-size: clamp(1.5rem, 4vw, 3.5rem); font-weight: 700; line-height: 1.15; 
    margin-bottom: 80px; letter-spacing: -1px; color: #eee;
    /* Ensure SplitType handles lines correctly */
    perspective: 400px;
  }
  
  /* SplitType styling to prevent layout shift */
  .word { display: inline-block; }
  .char { display: inline-block; transform-origin: center bottom; }

  /* FOOTER */
  .m-footer { height: 70vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 0 5vw; }
  .m-footer-title { font-size: clamp(2.5rem, 8vw, 6rem); font-weight: 900; margin-bottom: 40px; line-height: 1; letter-spacing: -2px; }
  .m-cta-btn { 
    text-decoration: none; color: #fff; border: 1px solid #fff;
    padding: 20px 40px; border-radius: 40px; font-size: 12px; font-weight: 800;
    transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1); display: inline-block;
  }
  .m-cta-btn:hover { background: #fff; color: #000; transform: scale(1.05); }

  /* THE DIAL ANCHOR */
  .manifesto-dial-anchor { position: fixed; bottom: 40px; left: 50%; transform: translateX(-50%); z-index: 100; pointer-events: auto; }
  .pod-morph-container { width: 60px; height: 60px; background: #111; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5); cursor: pointer; transition: transform 0.3s; }
  .pod-morph-container:hover { transform: scale(1.05); }
  .pod-dent { width: 4px; height: 4px; background: #333; border-radius: 50%; position: absolute; top: 10%; }
  .pod-center { width: 24px; height: 24px; background: #000; border: 1px solid #222; border-radius: 50%; display: flex; align-items: center; justify-content: center; }

  @media screen and (max-width: 768px) {
    .m-manifesto-grid { grid-template-columns: 1fr; gap: 20px; }
    .m-coord { position: static; margin-bottom: 20px; display: block; }
    .m-title { letter-spacing: -2px; }
    .m-paragraph { margin-bottom: 50px; }
  }
</style>

<script>
const runManifestoEngine = () => {
  const container = document.querySelector('#manifesto-{{ section.id }}');
  if(!container || !window.gsap || !window.THREE) return;

  // 1. THE BACKGROUND VOID (Three.js Atmospheric Fog)
  const canvas = container.querySelector('#void-canvas-{{ section.id }}');
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setSize(window.innerWidth, window.innerHeight);
  
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
  camera.position.z = 5;

  const geo = new THREE.BufferGeometry();
  const count = 600;
  const posArray = new Float32Array(count * 3);
  for(let i=0; i<count*3; i++) {
    posArray[i] = (Math.random() - 0.5) * 15;
  }
  geo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
  
  // Devil's Den Red Accent Particles
  const mat = new THREE.PointsMaterial({ size: 0.02, color: 0x8B0000, transparent: true, opacity: 0.6 });
  const points = new THREE.Points(geo, mat);
  scene.add(points);

  let targetY = 0;
  window.addEventListener('scroll', () => {
     targetY = window.scrollY * 0.0015;
  });

  const animate = () => {
    requestAnimationFrame(animate);
    points.rotation.y += 0.0005;
    // Smooth scroll interpolation for particles
    points.position.y += (targetY - points.position.y) * 0.05; 
    renderer.render(scene, camera);
  };
  animate();

  window.addEventListener('resize', () => {
    renderer.setSize(window.innerWidth, window.innerHeight);
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
  });

  // 2. KINETIC TEXT REVEAL (SplitType + GSAP)
  // Ensure SplitType is fully loaded before executing
  const initTypography = () => {
    if(typeof SplitType === 'undefined') {
       setTimeout(initTypography, 100);
       return;
    }

    const targets = container.querySelectorAll('.reveal-text');
    targets.forEach(target => {
      // Break paragraph into characters
      const split = new SplitType(target, { types: 'words, chars' });
      
      gsap.from(split.chars, {
        scrollTrigger: {
          trigger: target,
          start: "top 85%",
          end: "bottom 40%",
          scrub: 1, // Ties animation directly to scroll velocity
        },
        opacity: 0.1,
        y: 20,
        rotateX: -90,
        stagger: 0.05,
        ease: "power2.out"
      });
    });

    // Hero Entry Animation
    gsap.from('.m-title', { opacity: 0, y: 50, duration: 1.5, ease: "expo.out", delay: 0.2 });
    gsap.from('.m-glass-badge', { opacity: 0, scale: 0.8, duration: 1, ease: "power3.out" });
  };
  
  initTypography();
};

document.addEventListener('DOMContentLoaded', runManifestoEngine);
// Backup trigger if navigating via AJAX/Turbo
document.addEventListener('shopify:section:load', runManifestoEngine);
</script>

{% schema %}
{
  "name": "Damso Manifesto Engine",
  "settings": [],
  "presets": [
    {
      "name": "Damso Manifesto Engine"
    }
  ]
}
{% endschema %}