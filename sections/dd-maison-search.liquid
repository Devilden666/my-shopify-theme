<div class="maison-search-container">
  <div class="search-header">
    <h1 class="search-title">SEARCH RESULTS</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <input type="text" name="q" value="{{ search.terms | escape }}" placeholder="ENTER ARCHIVE QUERY">
      <button type="submit">SEARCH</button>
    </form>
  </div>

  <div class="maison-grid">
    {% if search.performed %}
      {% for item in search.results %}
        {% if item.object_type == 'product' %}
          <a href="{{ item.url }}" class="maison-card">
            <div class="m-card-image">
              <img src="{{ item.featured_image | image_url: width: 1000 }}" alt="{{ item.title }}" loading="lazy">
            </div>
            <div class="m-card-info">
              <h3 class="m-product-name">{{ item.title | upcase }}</h3>
              <p class="m-product-price">{{ item.price | money }}</p>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    {% else %}
      <p class="search-empty">INITIALIZING ARCHIVE SEARCH...</p>
    {% endif %}
  </div>
</div>

<style>
  .maison-search-container { background: #fff; min-height: 100vh; padding-bottom: 100px; }
  .search-header { padding: 150px 5vw 80px 5vw; border-bottom: 1px solid #eee; text-align: center; }
  .search-title { font-size: clamp(3rem, 10vw, 8rem); font-weight: 900; letter-spacing: -4px; margin-bottom: 40px; }
  .search-form { display: flex; justify-content: center; gap: 20px; }
  .search-form input { border: none; border-bottom: 1px solid #000; font-size: 14px; font-weight: 800; padding: 10px; width: 300px; outline: none; }
  .search-form button { background: #000; color: #fff; border: none; padding: 10px 30px; font-size: 11px; font-weight: 900; cursor: pointer; }
  
  .maison-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #eee; }
  .maison-card { background: #fff; text-decoration: none; color: #000; padding: 60px 40px; }
  .m-card-image { aspect-ratio: 3/4; margin-bottom: 20px; }
  .m-card-image img { width: 100%; height: 100%; object-fit: contain; }
  .m-product-name { font-size: 13px; font-weight: 900; }
  .m-product-price { font-family: monospace; font-size: 12px; }

  @media screen and (max-width: 768px) {
    .maison-grid { grid-template-columns: 1fr; }
    .search-form input { width: 60%; }
  }
</style>

{% schema %}
{
  "name": "Maison Search Grid",
  "settings": [],
  "presets": [
    {
      "name": "Maison Search Grid"
    }
  ]
}
{% endschema %}