      "settings": [
        { "type": "product", "id": "linked_product", "label": "Shopify Product" },
        { "type": "text", "id": "title", "label": "Override Title (Optional)" },
        { "type": "text", "id": "price", "label": "Override Price (Optional)" },
        { "type": "image_picker", "id": "image", "label": "Override Image (Optional)" }
      ]
    }
  ],
