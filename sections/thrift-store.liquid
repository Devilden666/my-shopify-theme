<style>
  /* --- CUSTOM STYLING & OPTIMIZATIONS --- */
  .thrift-vault-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 50px 15px; /* Tighter padding for mobile */
    font-family: inherit;
    overflow: hidden; 
  }
  @media (min-width: 768px) {
    .thrift-vault-container {
      padding: 80px 20px; /* Full padding for desktop */
    }
  }
  
  .thrift-vault-header {
    text-align: center;
    margin-bottom: 40px;
  }
  @media (min-width: 768px) {
    .thrift-vault-header { margin-bottom: 60px; }
  }
  
  /* Initial hidden states to prevent FOUC */
  .gsap-hide {
    visibility: hidden;
    opacity: 0;
  }

  .thrift-vault-header h2 {
    /* Fluid typography scales perfectly between mobile and desktop */
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 15px;
    color: #111;
  }
  
  .thrift-vault-divider {
    width: 60px;
    height: 4px;
    background-color: #000;
    margin: 0 auto;
  }
  
  /* GRID: 2 on mobile, 4 on desktop */
  .thrift-vault-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); 
    gap: 15px;
  }
  @media (min-width: 768px) {
    .thrift-vault-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 30px;
    }
  }

  /* INDIVIDUAL PRODUCT CARDS */
  .vault-item {
    background: #fff;
    border: 1px solid #eaeaea;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.4s ease, border-color 0.4s ease;
    will-change: transform, opacity; /* Forces GPU hardware acceleration */
  }
  
  /* IMAGE (PORTRAIT RATIO) */
  .vault-image-wrapper {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #f4f4f4;
    display: block;
  }
  .vault-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform; /* Smoother GSAP image settling */
  }
  
  /* VERIFIED BADGE */
  .vault-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #000;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 800;
    padding: 5px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
    z-index: 2;
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  }
  @media (min-width: 768px) {
    .vault-badge {
      top: 15px; left: 15px; font-size: 0.65rem; padding: 6px 12px; letter-spacing: 1.5px;
    }
  }

  /* TEXT AND BUTTONS */
  .vault-info {
    padding: 15px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    background: #fff;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .vault-info { padding: 24px; }
  }

  .vault-title {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    font-weight: 800;
    margin: 0 0 10px 0;
    color: #111;
    text-decoration: none;
    line-height: 1.3;
  }
  
  .vault-price-row {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .vault-price {
    font-size: clamp(1.1rem, 2.5vw, 1.25rem);
    font-weight: 900;
    color: #000;
  }
  .vault-btn {
    background: #000;
    color: #fff;
    padding: 8px 12px;
    border-radius: 6px;
    text-decoration: none;
    font-size: clamp(0.75rem, 1.5vw, 0.85rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }
  @media (min-width: 768px) {
    .vault-btn { padding: 10px 20px; border-radius: 8px; }
  }

  /* DESKTOP ONLY HOVER EFFECTS - Prevents sticky glitches on mobile touch */
  @media (hover: hover) and (pointer: fine) {
    .vault-item:hover {
      box-shadow: 0 15px 30px rgba(0,0,0,0.08);
      border-color: #ddd;
    }
    .vault-item:hover .vault-image-wrapper img {
      transform: scale(1.08) !important;
    }
    .vault-btn:hover {
      background: #333;
      transform: translateY(-2px);
    }
  }
</style>

<section class="thrift-vault-container">
  <div class="thrift-vault-header">
    <h2 class="gsap-hide">{{ section.settings.heading }}</h2>
    <div class="thrift-vault-divider gsap-hide"></div>
  </div>

  {% assign collection = collections[section.settings.vault_collection] %}

  <div class="thrift-vault-grid">
    {% if collection != blank and collection.products_count > 0 %}
      {% for product in collection.products limit: section.settings.product_limit %}
        <div class="vault-item gsap-hide">
          
          <a href="{{ product.url }}" class="vault-image-wrapper">
            {% if product.featured_image %}
              <img class="gsap-vault-img" 
                   src="{{ product.featured_image | image_url: width: 600 }}" 
                   srcset="{{ product.featured_image | image_url: width: 300 }} 300w, 
                           {{ product.featured_image | image_url: width: 600 }} 600w, 
                           {{ product.featured_image | image_url: width: 1000 }} 1000w"
                   sizes="(max-width: 768px) 50vw, 25vw"
                   width="{{ product.featured_image.width }}"
                   height="{{ product.featured_image.height }}"
                   alt="{{ product.title | escape }}" 
                   loading="lazy">
            {% endif %}
            <div class="vault-badge">Verified</div>
          </a>
          
          <div class="vault-info">
            <a href="{{ product.url }}" class="vault-title">{{ product.title }}</a>
            <div class="vault-price-row">
              <span class="vault-price">{{ product.price | money }}</span>
              <a href="{{ product.url }}" class="vault-btn">View Piece</a>
            </div>
          </div>

        </div>
      {% endfor %}
    {% else %}
      <p style="text-align:center; grid-column: 1 / -1; color: #666; padding: 40px 0;">
        The vault is currently empty. Check back soon.
      </p>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", (event) => {
    // Ensure GSAP is loaded before firing
    if (typeof gsap !== "undefined" && typeof ScrollTrigger !== "undefined") {
      
      const isMobile = window.innerWidth < 768;

      // 1. Header Animation Timeline
      const headerTl = gsap.timeline({
        scrollTrigger: {
          trigger: ".thrift-vault-container",
          start: "top 85%", // Trigger slightly later on mobile to ensure it's in view
        }
      });

      headerTl.fromTo(".thrift-vault-header h2", 
        { autoAlpha: 0, y: 30 }, 
        { autoAlpha: 1, y: 0, duration: 0.8, ease: "power4.out" }
      )
      .fromTo(".thrift-vault-divider", 
        { autoAlpha: 0, scaleX: 0, transformOrigin: "center" }, 
        { autoAlpha: 1, scaleX: 1, duration: 0.6, ease: "power3.inOut" }, 
        "-=0.5"
      );

      // 2. Grid Cards Stagger Animation
      ScrollTrigger.batch(".vault-item", {
        start: "top 90%",
        onEnter: (elements, triggers) => {
          // Faster, lighter animation stagger on mobile
          gsap.fromTo(elements, 
            { autoAlpha: 0, y: isMobile ? 40 : 80 }, 
            { autoAlpha: 1, y: 0, stagger: isMobile ? 0.1 : 0.15, duration: 0.8, ease: "power3.out", overwrite: true }
          );
          
          const images = elements.map(el => el.querySelector('.gsap-vault-img'));
          gsap.fromTo(images,
            { scale: isMobile ? 1.15 : 1.3 }, // Less aggressive scaling on mobile hardware
            { scale: 1, stagger: isMobile ? 0.1 : 0.15, duration: 1.2, ease: "power2.out", overwrite: true }
          );
        }
      });

    } else {
      console.warn("GSAP or ScrollTrigger not found on this page. Unhiding elements cleanly.");
      document.querySelectorAll('.gsap-hide').forEach(el => {
        el.style.visibility = 'visible';
        el.style.opacity = '1';
      });
    }
  });
</script>

{% schema %}
{
  "name": "GSAP Thrift Vault Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Vault"
    },
    {
      "type": "collection",
      "id": "vault_collection",
      "label": "Select Vault Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Maximum products to show",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "GSAP Thrift Vault Grid",
      "category": "Custom"
    }
  ]
}
{% endschema %}